# Database
DATABASE_URL="postgresql://user:password@localhost:5432/beyond"

# Next Auth (future)
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Beyond"

# ─── Integrations ─────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting integration credentials at rest.
# Must be exactly 32 bytes: provide as a 64-char hex string.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATIONS_ENCRYPTION_KEY="your-64-char-hex-key-here"

# ─── Webhook signature secrets ────────────────────────────────────────────────
# HMAC-SHA256 signing secrets for inbound order webhooks.
# If omitted, signature verification is skipped (useful for local dev).
# Obtain from each platform's developer dashboard.
UBER_EATS_WEBHOOK_SECRET=""
DOORDASH_WEBHOOK_SECRET=""
