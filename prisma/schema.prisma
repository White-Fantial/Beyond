generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

// @deprecated — use CatalogOriginType instead.
// Kept for migration compatibility; all new code should use originType.
enum CatalogSourceType {
  POS
  DELIVERY
  LOCAL
  MERGED
  IMPORTED
}

// Phase 1: Internal catalog ownership.
// Records where a catalog entity ORIGINALLY came from (historical provenance only).
// This is NOT the current authoritative source — Beyond internal catalog IS the
// canonical operational model regardless of origin.
enum CatalogOriginType {
  BEYOND_CREATED      // created directly inside Beyond
  IMPORTED_FROM_POS   // initially imported from a POS system
  IMPORTED_FROM_DELIVERY // initially imported from a delivery platform
  IMPORTED_FROM_OTHER // initially imported from another source
}

enum CatalogChannelType {
  LOYVERSE
  UBER_EATS
  DOORDASH
  ONLINE_ORDER
  SUBSCRIPTION
  OTHER
}

enum CatalogEntityType {
  CATEGORY
  PRODUCT
  MODIFIER_GROUP
  MODIFIER_OPTION
}

enum MappingStatus {
  ACTIVE
  BROKEN
  PENDING
  DISCONNECTED
}

// Phase 3: Catalog mapping layer enums.

enum CatalogMappingStatus {
  ACTIVE
  NEEDS_REVIEW
  UNMATCHED
  BROKEN
  ARCHIVED
}

enum CatalogMappingSource {
  AUTO
  MANUAL
  IMPORT_SEEDED
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  ARCHIVED
}

enum PlatformRole {
  USER
  PLATFORM_ADMIN
  PLATFORM_SUPPORT
}

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  ANALYST
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum StoreStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum StoreRole {
  OWNER
  ADMIN
  MANAGER
  SUPERVISOR
  STAFF
}

enum StoreMembershipStatus {
  ACTIVE
  INACTIVE
  REMOVED
}

enum ConnectionType {
  POS
  DELIVERY
  PAYMENT
}

enum ConnectionProvider {
  LOYVERSE
  LIGHTSPEED
  UBER_EATS
  DOORDASH
  STRIPE
  OTHER
}

enum ConnectionStatus {
  NOT_CONNECTED
  CONNECTING
  CONNECTED
  ERROR
  REAUTH_REQUIRED
  DISCONNECTED
}

enum ProviderEnvironment {
  SANDBOX
  PRODUCTION
}

enum AuthScheme {
  OAUTH2
  JWT_BEARER
  API_KEY
  BASIC
  CUSTOM
}

enum CredentialType {
  OAUTH_TOKEN
  CLIENT_CREDENTIAL
  JWT_SIGNING_KEY
  JWT_ASSERTION
  API_KEY
  WEBHOOK_SECRET
  CUSTOM_SECRET
}

enum ConnectionActionType {
  CONNECT_START
  CONNECT_CALLBACK
  CONNECT_SUCCESS
  CONNECT_FAILURE
  REFRESH_SUCCESS
  REFRESH_FAILURE
  DISCONNECT
  REAUTHORIZE
  STORE_MAPPING_UPDATE
  SYNC_TEST
}

enum SyncStatus {
  NEVER
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

// ─── Billing Enums ────────────────────────────────────────────────────────────

enum PlanStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum BillingInterval {
  MONTHLY
  YEARLY
  CUSTOM
}

enum SubscriptionStatus {
