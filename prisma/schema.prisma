  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
  INCOMPLETE
}

enum SubscriptionEventType {
  PLAN_ASSIGNED
  PLAN_CHANGED
  TRIAL_EXTENDED
  STATUS_CHANGED
  CANCEL_AT_PERIOD_END_SET
