// ─── Feature Flags ────────────────────────────────────────────────────────────

enum FlagType {
  BOOLEAN
  STRING
  INTEGER
  JSON
  VARIANT
}

enum FlagStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum FlagScopeType {
