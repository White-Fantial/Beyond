// ─── Foundation Models ────────────────────────────────────────────────────────

model Tenant {
  id          String       @id @default(uuid())
  slug        String       @unique
  legalName   String
  displayName String
  status      TenantStatus @default(ACTIVE)
  timezone    String
  currency    String
  countryCode String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  archivedAt  DateTime?

  stores           Store[]
  memberships      Membership[]
  storeMemberships StoreMembership[]
  connections      Connection[]
  auditLogs        AuditLog[]

  billingAccount       TenantBillingAccount?
  subscriptions        TenantSubscription[]
  subscriptionEvents   TenantSubscriptionEvent[]
  billingRecords       BillingRecord[]
  usageSnapshots       UsageSnapshot[]
  billingInvoices      BillingInvoice[]
  paymentAttempts      PaymentAttempt[]
  usageMetricSnapshots UsageMetricSnapshot[]
  billingChangeRequests SubscriptionChangeRequest[]

  customers Customer[]

  alertRules    AlertRule[]
  notifications Notification[]
  promoCodes    PromoCode[]
  giftCards     GiftCard[]
  webhookEndpoints WebhookEndpoint[]
  productReviews ProductReview[]
  supportTickets SupportTicket[]

  @@map("tenants")
}

model User {
  id                 String       @id @default(uuid())
  email              String       @unique
  name               String
  phone              String?
  passwordHash       String?
  authProvider       String?
  authProviderUserId String?
  platformRole       PlatformRole @default(USER)
  status             UserStatus   @default(ACTIVE)
  lastLoginAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  archivedAt         DateTime?

  memberships              Membership[]           @relation("UserMemberships")
  invitedMemberships       Membership[]           @relation("MembershipInvitedBy")
  auditLogs                AuditLog[]             @relation("AuditLogActor")
  jobRuns                  JobRun[]
  notifications            Notification[]
  alertRulesCreated        AlertRule[]            @relation("AlertRuleCreatedBy")
  customerNotifications    CustomerNotification[]
  customerAddresses        CustomerAddress[]
  loyaltyAccount           LoyaltyAccount?
  savedPaymentMethods      SavedPaymentMethod[]
  promoCodesCreated        PromoCode[]            @relation("PromoCodeCreatedBy")
  productReviews           ProductReview[]        @relation("UserProductReviews")
  supportTickets           SupportTicket[]        @relation("UserSupportTickets")
  ticketMessages           SupportTicketMessage[] @relation("UserTicketMessages")
  pushSubscriptions        PushSubscription[]
  pushPreference           PushPreference?

  @@map("users")
}

model Membership {
  id              String           @id @default(uuid())
  tenantId        String
  userId          String
  role            MembershipRole
  status          MembershipStatus @default(INVITED)
  invitedByUserId String?
  joinedAt        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User              @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)
  invitedByUser    User?             @relation("MembershipInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  storeMemberships StoreMembership[]

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@map("memberships")
}

model Store {
  id           String      @id @default(uuid())
  tenantId     String
  code         String
  name         String
  displayName  String
  status       StoreStatus @default(ACTIVE)
  phone        String?
  email        String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  region       String?
  postalCode   String?
  countryCode  String
  timezone     String
  currency     String
  openingDate  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  archivedAt   DateTime?

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeMemberships StoreMembership[]
  connections      Connection[]
  auditLogs        AuditLog[]        @relation("AuditLogStore")

  categories           Category[]
  menuItems            MenuItem[]
  legacyOrders         LegacyOrder[]
  posIntegrations      PosIntegration[]
  deliveryIntegrations DeliveryIntegration[]
  subscriptionPlans    SubscriptionPlan[]

  storeSettings          StoreSettings?
  catalogSettings        CatalogSettings?
  storeOperationSettings StoreOperationSettings?
  storeHours             StoreHours[]
  alertRules             AlertRule[]
  promoCodes             PromoCode[]
  giftCards              GiftCard[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  @@map("stores")
}

model StoreMembership {
  id           String                @id @default(uuid())
  tenantId     String
  membershipId String
  storeId      String
  role         StoreRole
  status       StoreMembershipStatus @default(ACTIVE)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([membershipId, storeId])
  @@index([tenantId])
  @@index([storeId])
  @@index([membershipId])
  @@index([status])
  @@map("store_memberships")
}

model ProviderAppCredential {
  id               String              @id @default(cuid())
  tenantId         String?
  provider         ConnectionProvider
  environment      ProviderEnvironment @default(PRODUCTION)
  displayName      String
  authScheme       AuthScheme
  clientId         String?
  keyId            String?
  developerId      String?
  scopes           String[]            @default([])
  configEncrypted  String
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  connections Connection[]

  @@index([tenantId, provider, environment, isActive])
  @@map("provider_app_credentials")
}

model Connection {
  id                    String             @id @default(cuid())
  tenantId              String
  storeId               String
  type                  ConnectionType
  provider              ConnectionProvider
  status                ConnectionStatus   @default(NOT_CONNECTED)
  displayName           String?
  externalMerchantId    String?
  externalStoreId       String?
  externalStoreName     String?
  externalLocationId    String?
  authScheme            AuthScheme?
  appCredentialId       String?
  capabilitiesJson      Json?
  metadataJson          Json?
  lastConnectedAt       DateTime?
  lastAuthValidatedAt   DateTime?
  lastSyncAt            DateTime?
  lastSyncStatus        String?
  lastErrorCode         String?
  lastErrorMessage      String?
  reauthRequiredAt      DateTime?
  disconnectedAt        DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store         Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  appCredential ProviderAppCredential? @relation(fields: [appCredentialId], references: [id], onDelete: SetNull)
  credentials   ConnectionCredential[]
  actionLogs    ConnectionActionLog[]
  catalogSettings CatalogSettings[]

  @@unique([storeId, provider, type])
  @@index([tenantId, storeId, provider])
  @@index([status, reauthRequiredAt])
  @@map("connections")
}

model ConnectionCredential {
  id                  String         @id @default(cuid())
  tenantId            String
  storeId             String
  connectionId        String
  credentialType      CredentialType
  authScheme          AuthScheme
  label               String?
  version             Int            @default(1)
  configEncrypted     String
  tokenReferenceHash  String?
  issuedAt            DateTime?
  expiresAt           DateTime?
  refreshAfter        DateTime?
  lastUsedAt          DateTime?
  lastRefreshAt       DateTime?
  lastRefreshStatus   String?
  lastRefreshError    String?
  canRefresh          Boolean        @default(false)
  requiresReauth      Boolean        @default(false)
  isActive            Boolean        @default(true)
  rotatedAt           DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, isActive])
  @@index([credentialType, authScheme])
  @@index([expiresAt, refreshAfter])
  @@index([tenantId, storeId])
  @@map("connection_credentials")
}

model ConnectionOAuthState {
  id                String             @id @default(cuid())
  tenantId          String
  storeId           String
  provider          ConnectionProvider
  connectionType    ConnectionType
  state             String             @unique
  codeVerifier      String?
  redirectUri       String
  requestedByUserId String
  expiresAt         DateTime
  consumedAt        DateTime?
  metadataJson      Json?
  createdAt         DateTime           @default(now())

  @@index([provider, expiresAt])
  @@index([tenantId, storeId])
  @@map("connection_oauth_states")
}

model ConnectionActionLog {
  id           String               @id @default(cuid())
  tenantId     String
  storeId      String
  connectionId String?
  provider     ConnectionProvider
  actionType   ConnectionActionType
  status       String
  actorUserId  String?
  message      String?
  errorCode    String?
  payloadJson  Json?
  createdAt    DateTime             @default(now())

  connection Connection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([tenantId, storeId, provider, createdAt])
  @@index([connectionId, createdAt])
  @@map("connection_action_logs")
}

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String?
  storeId      String?
  actorUserId  String?
  action       String
  targetType   String
  targetId     String
  metadataJson Json?
  createdAt    DateTime @default(now())

  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  store     Store?  @relation("AuditLogStore", fields: [storeId], references: [id], onDelete: SetNull)
  actorUser User?   @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([storeId, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

// ─── RBAC (kept as-is) ────────────────────────────────────────────────────────

model Role {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String?

  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ─── Catalog ──────────────────────────────────────────────────────────────────

model Category {
  id           String   @id @default(cuid())
  storeId      String
  name         String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store     Store      @relation(fields: [storeId], references: [id])
  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id          String   @id @default(cuid())
  storeId     String
  categoryId  String
  name        String
  description String?
  price       Int
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store        Store            @relation(fields: [storeId], references: [id])
  category     Category         @relation(fields: [categoryId], references: [id])
  optionGroups OptionGroup[]
  legacyOrderItems LegacyOrderItem[]

  @@map("menu_items")
}

model OptionGroup {
  id            String  @id @default(cuid())
  menuItemId    String
  name          String
  isRequired    Boolean @default(false)
  maxSelections Int     @default(1)

  menuItem MenuItem     @relation(fields: [menuItemId], references: [id])
  options  MenuOption[]

  @@map("option_groups")
}

model MenuOption {
  id              String @id @default(cuid())
  optionGroupId   String
  name            String
  additionalPrice Int    @default(0)

  optionGroup OptionGroup @relation(fields: [optionGroupId], references: [id])

  @@map("menu_options")
}

// ─── Legacy Orders (deprecated — superseded by canonical Order model below) ────

/// @deprecated Use the canonical Order model instead.
model LegacyOrder {
  id              String   @id @default(cuid())
  storeId         String
  channelType     String
  externalOrderId String?
  status          String   @default("PENDING")
  totalAmount     Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store   Store            @relation(fields: [storeId], references: [id])
  items   LegacyOrderItem[]
  payment LegacyPayment?

  @@map("legacy_orders")
}

/// @deprecated Use the canonical OrderItem model instead.
model LegacyOrderItem {
  id         String @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Int
  totalPrice Int
  options    Json?

  order    LegacyOrder @relation(fields: [orderId], references: [id])
  menuItem MenuItem    @relation(fields: [menuItemId], references: [id])

  @@map("legacy_order_items")
}

/// @deprecated Payment for legacy orders.
model LegacyPayment {
  id                    String    @id @default(cuid())
  orderId               String    @unique
  storeId               String
  method                String
  status                String    @default("PENDING")
  amount                Int
  provider              String?
  externalTransactionId String?
  paidAt                DateTime?
  createdAt             DateTime  @default(now())

  order LegacyOrder @relation(fields: [orderId], references: [id])

  @@map("legacy_payments")
}

// ─── Order Enums ──────────────────────────────────────────────────────────────

/// The channel that originated this order.
enum OrderSourceChannel {
  POS
  UBER_EATS
  DOORDASH
  ONLINE
  SUBSCRIPTION
  MANUAL
  UNKNOWN
}

/// Channel types used for order channel links.
enum OrderChannelType {
  POS
  UBER_EATS
  DOORDASH
  ONLINE
  SUBSCRIPTION
  MANUAL
}

/// Role of a channel link relative to an order.
enum OrderChannelRole {
  SOURCE     // This channel originated the order.
  FORWARDED  // The order was forwarded/sent to this channel.
  MIRROR     // Sync/reconciliation mirror record.
}

/// Direction of the channel link event.
enum OrderLinkDirection {
  INBOUND   // External → Beyond
  OUTBOUND  // Beyond → External
}

/// Canonical order lifecycle status.
enum OrderStatus {
  RECEIVED
  ACCEPTED
  IN_PROGRESS
  READY
  COMPLETED
  CANCELLED
  FAILED
}

/// Tracks the state of forwarding an order to POS for docket printing.
enum PosSubmissionStatus {
  NOT_REQUIRED
  PENDING
  SENT
  ACCEPTED
  FAILED
  SKIPPED
}

/// Audit event types recorded in OrderEvent.
enum OrderEventType {
  ORDER_RECEIVED
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_STATUS_CHANGED
  POS_FORWARD_REQUESTED
  POS_FORWARD_SENT
  POS_FORWARD_ACCEPTED
  POS_FORWARD_FAILED
  POS_RECONCILED
  ORDER_CANCELLED
  RAW_WEBHOOK_RECEIVED
  RAW_SYNC_RECEIVED
}

// ─── Canonical Orders ─────────────────────────────────────────────────────────

/// Canonical order — one record per real customer purchase regardless of source channel.
model Order {
  id       String @id @default(uuid())
  tenantId String
  storeId  String

  // ── Source channel ────────────────────────────────────────────────────────
  sourceChannel     OrderSourceChannel
  sourceConnectionId String?
  /// External order ref from the originating channel (e.g. Uber order id, POS receipt id).
  sourceOrderRef    String?
  sourceCustomerRef String?
  originSubmittedAt DateTime?

  // ── Lifecycle timestamps ──────────────────────────────────────────────────
  orderedAt    DateTime
  acceptedAt   DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?

  // ── Status ────────────────────────────────────────────────────────────────
  status OrderStatus @default(RECEIVED)

  // ── Money (integer minor units, e.g. cents / pence) ──────────────────────
  subtotalAmount Int    @default(0)
  discountAmount Int    @default(0)
  taxAmount      Int    @default(0)
  tipAmount      Int    @default(0)
  totalAmount    Int    @default(0)
  currencyCode   String @default("NZD")

  // ── Customer display ──────────────────────────────────────────────────────
  customerId    String?
  customerName  String?
  customerPhone String?
  customerEmail String?

  // ── POS forwarding ────────────────────────────────────────────────────────
  posForwardingRequired Boolean           @default(false)
  posConnectionId       String?
  posSubmissionStatus   PosSubmissionStatus @default(NOT_REQUIRED)
  /// External order ref assigned by the POS system after acceptance.
  posOrderRef           String?
  posSubmittedAt        DateTime?
  posAcceptedAt         DateTime?

  // ── Idempotency / deduplication ───────────────────────────────────────────
  /// Composite idempotency key, e.g. "UBER_EATS:<storeId>:<uberOrderId>".
  /// Partial-unique enforced at DB level (only when non-null).
  canonicalOrderKey       String?
  /// True when Beyond itself created the record in the external system (e.g. POS-forwarded orders).
  externalCreatedByBeyond Boolean @default(false)

  notes          String?
  /// Snapshot of the raw source payload as received.
  rawSourcePayload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ─────────────────────────────────────────────────────────────
  items        OrderItem[]
  channelLinks OrderChannelLink[]
  events       OrderEvent[]

  @@index([tenantId, storeId, orderedAt])
  @@index([tenantId, storeId, sourceChannel])
  @@index([sourceConnectionId, sourceOrderRef])
  @@index([posConnectionId, posOrderRef])
  // Partial unique on canonicalOrderKey is enforced via a raw SQL migration index
  // (see migration 20260331000000) rather than a Prisma @@unique to handle nulls correctly.
  @@map("orders")
}

/// Line item within a canonical order.
model OrderItem {
  id       String @id @default(uuid())
  orderId  String
  tenantId String
  storeId  String

  productId        String?
  productName      String
  productSku       String?
  sourceProductRef String?
  quantity         Int
  unitPriceAmount  Int
  totalPriceAmount Int

  notes      String?
  rawPayload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  modifiers OrderItemModifier[]

  @@index([orderId])
  @@index([tenantId, storeId])
  @@map("order_items")
}

/// Modifier/option applied to an order line item.
model OrderItemModifier {
  id          String @id @default(uuid())
  orderItemId String
  tenantId    String
  storeId     String

  modifierGroupId    String?
  modifierOptionId   String?
  modifierGroupName  String?
  modifierOptionName String
  quantity           Int     @default(1)
  unitPriceAmount    Int     @default(0)
  totalPriceAmount   Int     @default(0)

  sourceModifierGroupRef  String?
  sourceModifierOptionRef String?
  rawPayload              Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([tenantId, storeId])
  @@map("order_item_modifiers")
}

/// Per-channel link record: tracks source, forward, and mirror connections for an order.
/// - SOURCE link: the channel that originated the order (one per order).
/// - FORWARDED link: the order was sent outbound to this channel (e.g. POS for docket printing).
/// - MIRROR link: a reconciliation/sync record tying the order to a channel record.
model OrderChannelLink {
  id       String @id @default(uuid())
  orderId  String
  tenantId String
  storeId  String

  channelType  OrderChannelType
  connectionId String?
  role         OrderChannelRole
  direction    OrderLinkDirection

  externalOrderRef    String?
  externalDisplayRef  String?
  externalStatus      String?
  externalCreatedAt   DateTime?
  externalUpdatedAt   DateTime?

  requestPayload  Json?
  responsePayload Json?
  rawPayload      Json?

  /// How this link was established: "webhook", "sync", "forward-response", "manual".
  linkedBy         String?
  createdByBeyond  Boolean @default(false)

