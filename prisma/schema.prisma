generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CatalogSourceType {
  POS
  DELIVERY
  LOCAL
  MERGED
  IMPORTED
}

enum CatalogChannelType {
  LOYVERSE
  UBER_EATS
  DOORDASH
  ONLINE_ORDER
  SUBSCRIPTION
  OTHER
}

enum CatalogEntityType {
  CATEGORY
  PRODUCT
  MODIFIER_GROUP
  MODIFIER_OPTION
}

enum MappingStatus {
  ACTIVE
  BROKEN
  PENDING
  DISCONNECTED
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  ARCHIVED
}

enum PlatformRole {
  USER
  PLATFORM_ADMIN
  PLATFORM_SUPPORT
}

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  ANALYST
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum StoreStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum StoreRole {
  OWNER
  ADMIN
  MANAGER
  SUPERVISOR
  STAFF
}

enum StoreMembershipStatus {
  ACTIVE
  INACTIVE
  REMOVED
}

enum ConnectionType {
  POS
  DELIVERY
  PAYMENT
}

enum ConnectionProvider {
  LOYVERSE
  UBER_EATS
  DOORDASH
  STRIPE
  OTHER
}

enum ConnectionStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  PENDING
}

enum SyncStatus {
  NEVER
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

// ─── Foundation Models ────────────────────────────────────────────────────────

model Tenant {
  id          String       @id @default(uuid())
  slug        String       @unique
  legalName   String
  displayName String
  status      TenantStatus @default(ACTIVE)
  timezone    String
  currency    String
  countryCode String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  archivedAt  DateTime?

  stores           Store[]
  memberships      Membership[]
  storeMemberships StoreMembership[]
  connections      Connection[]
  auditLogs        AuditLog[]

  @@map("tenants")
}

model User {
  id                 String       @id @default(uuid())
  email              String       @unique
  name               String
  phone              String?
  passwordHash       String?
  authProvider       String?
  authProviderUserId String?
  platformRole       PlatformRole @default(USER)
  status             UserStatus   @default(ACTIVE)
  lastLoginAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  archivedAt         DateTime?

  memberships        Membership[] @relation("UserMemberships")
  invitedMemberships Membership[] @relation("MembershipInvitedBy")
  auditLogs          AuditLog[]   @relation("AuditLogActor")

  @@map("users")
}

model Membership {
  id              String           @id @default(uuid())
  tenantId        String
  userId          String
  role            MembershipRole
  status          MembershipStatus @default(INVITED)
  invitedByUserId String?
  joinedAt        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User              @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)
  invitedByUser    User?             @relation("MembershipInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  storeMemberships StoreMembership[]

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@map("memberships")
}

model Store {
  id           String      @id @default(uuid())
  tenantId     String
  code         String
  name         String
  displayName  String
  status       StoreStatus @default(ACTIVE)
  phone        String?
  email        String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  region       String?
  postalCode   String?
  countryCode  String
  timezone     String
  currency     String
  openingDate  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  archivedAt   DateTime?

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeMemberships StoreMembership[]
  connections      Connection[]
  auditLogs        AuditLog[]        @relation("AuditLogStore")

  categories           Category[]
  menuItems            MenuItem[]
  orders               Order[]
  posIntegrations      PosIntegration[]
  deliveryIntegrations DeliveryIntegration[]
  subscriptionPlans    SubscriptionPlan[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  @@map("stores")
}

model StoreMembership {
  id           String                @id @default(uuid())
  tenantId     String
  membershipId String
  storeId      String
  role         StoreRole
  status       StoreMembershipStatus @default(ACTIVE)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([membershipId, storeId])
  @@index([tenantId])
  @@index([storeId])
  @@index([membershipId])
  @@index([status])
  @@map("store_memberships")
}

model Connection {
  id                 String             @id @default(uuid())
  tenantId           String
  storeId            String
  type               ConnectionType
  provider           ConnectionProvider
  status             ConnectionStatus   @default(PENDING)
  displayName        String?
  externalAccountId  String?
  externalLocationId String?
  connectedAt        DateTime?
  disconnectedAt     DateTime?
  lastSyncAt         DateTime?
  lastSyncStatus     SyncStatus         @default(NEVER)
  lastErrorCode      String?
  lastErrorMessage   String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store       Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  credentials ConnectionCredential[]

  @@unique([storeId, type, provider])
  @@index([tenantId])
  @@index([storeId])
  @@index([type])
  @@index([provider])
  @@index([status])
  @@map("connections")
}

model ConnectionCredential {
  id              String    @id @default(uuid())
  connectionId    String
  version         Int       @default(1)
  isActive        Boolean   @default(true)
  configEncrypted String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  rotatedAt       DateTime?

  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([isActive])
  @@map("connection_credentials")
}

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String?
  storeId      String?
  actorUserId  String?
  action       String
  targetType   String
  targetId     String
  metadataJson Json?
  createdAt    DateTime @default(now())

  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  store     Store?  @relation("AuditLogStore", fields: [storeId], references: [id], onDelete: SetNull)
  actorUser User?   @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([storeId, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

// ─── RBAC (kept as-is) ────────────────────────────────────────────────────────

model Role {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String?

  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ─── Catalog ──────────────────────────────────────────────────────────────────

model Category {
  id           String   @id @default(cuid())
  storeId      String
  name         String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store     Store      @relation(fields: [storeId], references: [id])
  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id          String   @id @default(cuid())
  storeId     String
  categoryId  String
  name        String
  description String?
  price       Int
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store        Store         @relation(fields: [storeId], references: [id])
  category     Category      @relation(fields: [categoryId], references: [id])
  optionGroups OptionGroup[]
  orderItems   OrderItem[]

  @@map("menu_items")
}

model OptionGroup {
  id            String  @id @default(cuid())
  menuItemId    String
  name          String
  isRequired    Boolean @default(false)
  maxSelections Int     @default(1)

  menuItem MenuItem     @relation(fields: [menuItemId], references: [id])
  options  MenuOption[]

  @@map("option_groups")
}

model MenuOption {
  id              String @id @default(cuid())
  optionGroupId   String
  name            String
  additionalPrice Int    @default(0)

  optionGroup OptionGroup @relation(fields: [optionGroupId], references: [id])

  @@map("menu_options")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id              String   @id @default(cuid())
  storeId         String
  channelType     String
  externalOrderId String?
  status          String   @default("PENDING")
  totalAmount     Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store   Store       @relation(fields: [storeId], references: [id])
  items   OrderItem[]
  payment Payment?

  @@map("orders")
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Int
  totalPrice Int
  options    Json?

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

model Payment {
  id                    String    @id @default(cuid())
  orderId               String    @unique
  storeId               String
  method                String
  status                String    @default("PENDING")
  amount                Int
  provider              String?
  externalTransactionId String?
  paidAt                DateTime?
  createdAt             DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ─── Integrations ─────────────────────────────────────────────────────────────

model PosIntegration {
  id              String    @id @default(cuid())
  storeId         String
  provider        String
  status          String    @default("DISCONNECTED")
  externalStoreId String?
  config          Json?
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, provider])
  @@map("pos_integrations")
}

model DeliveryIntegration {
  id             String    @id @default(cuid())
  storeId        String
  platform       String
  status         String    @default("DISCONNECTED")
  externalShopId String?
  config         Json?
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, platform])
  @@map("delivery_integrations")
}

// ─── Subscriptions ────────────────────────────────────────────────────────────

model SubscriptionPlan {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  price     Int
  interval  String
  benefits  Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store         Store          @relation(fields: [storeId], references: [id])
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id              String    @id @default(cuid())
  planId          String
  customerId      String
  status          String    @default("ACTIVE")
  startDate       DateTime
  nextBillingDate DateTime
  cancelledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

// ─── Internal Catalog ─────────────────────────────────────────────────────────

model CatalogCategory {
  id                       String            @id @default(uuid())
  tenantId                 String
  storeId                  String
  sourceType               CatalogSourceType
  sourceOfTruthConnectionId String?
  sourceCategoryRef        String?
  name                     String
  description              String?
  slug                     String?
  displayOrder             Int               @default(0)
  isActive                 Boolean           @default(true)
  isVisibleOnOnlineOrder   Boolean           @default(true)
  isVisibleOnSubscription  Boolean           @default(false)
  imageUrl                 String?
  metadata                 Json              @default("{}")
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  deletedAt                DateTime?

  productCategories CatalogProductCategory[]

  @@index([tenantId, storeId])
  @@index([storeId, isActive, isVisibleOnOnlineOrder, displayOrder])
  @@index([storeId, sourceOfTruthConnectionId, sourceCategoryRef])
  @@map("catalog_categories")
}

model CatalogProduct {
  id                        String            @id @default(uuid())
  tenantId                  String
  storeId                   String
  sourceType                CatalogSourceType
  sourceOfTruthConnectionId String?
  sourceProductRef          String?
  sku                       String?
  barcode                   String?
  name                      String
  description               String?
  shortDescription          String?
  basePriceAmount           Int               @default(0)
  currency                  String            @default("NZD")
  imageUrl                  String?
  displayOrder              Int               @default(0)
  isActive                  Boolean           @default(true)
  isSellable                Boolean           @default(true)
  isVisibleOnOnlineOrder    Boolean           @default(true)
  isVisibleOnSubscription   Boolean           @default(false)
  isFeatured                Boolean           @default(false)
  posName                   String?
  onlineName                String?
  subscriptionName          String?
  internalNote              String?
  metadata                  Json              @default("{}")
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  deletedAt                 DateTime?

  productCategories     CatalogProductCategory[]
  productModifierGroups CatalogProductModifierGroup[]

  @@index([tenantId, storeId])
  @@index([storeId, isActive, isVisibleOnOnlineOrder, displayOrder])
  @@index([storeId, sourceOfTruthConnectionId, sourceProductRef])
  @@index([storeId, name])
  @@map("catalog_products")
}

model CatalogProductCategory {
  id         String   @id @default(uuid())
  tenantId   String
  storeId    String
  productId  String
  categoryId String
  sortOrder  Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  product  CatalogProduct  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category CatalogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
  @@index([storeId, categoryId, sortOrder])
  @@index([storeId, productId])
  @@map("catalog_product_categories")
}

model CatalogModifierGroup {
  id                        String            @id @default(uuid())
  tenantId                  String
  storeId                   String
  sourceType                CatalogSourceType
  sourceOfTruthConnectionId String?
  sourceModifierGroupRef    String?
  name                      String
  description               String?
  selectionMin              Int               @default(0)
  selectionMax              Int?
  isRequired                Boolean           @default(false)
  displayOrder              Int               @default(0)
  isActive                  Boolean           @default(true)
  isVisibleOnOnlineOrder    Boolean           @default(true)
  metadata                  Json              @default("{}")
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  deletedAt                 DateTime?

  modifierOptions       CatalogModifierOption[]
  productModifierGroups CatalogProductModifierGroup[]

  @@index([tenantId, storeId])
  @@index([storeId, sourceOfTruthConnectionId, sourceModifierGroupRef])
  @@index([storeId, isActive, displayOrder])
  @@map("catalog_modifier_groups")
}

model CatalogModifierOption {
  id                        String            @id @default(uuid())
  tenantId                  String
  storeId                   String
  modifierGroupId           String
  sourceType                CatalogSourceType
  sourceOfTruthConnectionId String?
  sourceModifierOptionRef   String?
  name                      String
  description               String?
  priceDeltaAmount          Int               @default(0)
  currency                  String            @default("NZD")
  displayOrder              Int               @default(0)
  isDefault                 Boolean           @default(false)
  isActive                  Boolean           @default(true)
  isSoldOut                 Boolean           @default(false)
  metadata                  Json              @default("{}")
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  deletedAt                 DateTime?

  modifierGroup CatalogModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@index([tenantId, storeId])
  @@index([modifierGroupId, isActive, isSoldOut, displayOrder])
  @@index([storeId, sourceOfTruthConnectionId, sourceModifierOptionRef])
  @@map("catalog_modifier_options")
}

model CatalogProductModifierGroup {
  id                  String   @id @default(uuid())
  tenantId            String
  storeId             String
  productId           String
  modifierGroupId     String
  displayOrder        Int      @default(0)
  overrideSelectionMin Int?
  overrideSelectionMax Int?
  overrideRequired    Boolean?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  product       CatalogProduct       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroup CatalogModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@unique([productId, modifierGroupId])
  @@index([storeId, productId, displayOrder])
  @@index([storeId, modifierGroupId])
  @@map("catalog_product_modifier_groups")
}

// ─── External Raw Mirror Tables ───────────────────────────────────────────────

model ExternalCatalogCategory {
  id                String           @id @default(uuid())
  tenantId          String
  storeId           String
  connectionId      String
  channelType       CatalogChannelType
  externalId        String
  externalParentId  String?
  normalizedName    String?
  rawPayload        Json
  externalUpdatedAt DateTime?
  syncChecksum      String?
  lastSyncedAt      DateTime         @default(now())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([connectionId, externalId])
  @@index([storeId, connectionId])
  @@map("external_catalog_categories")
}

model ExternalCatalogProduct {
  id                    String           @id @default(uuid())
  tenantId              String
  storeId               String
  connectionId          String
  channelType           CatalogChannelType
  externalId            String
  externalParentId      String?
  normalizedName        String?
  normalizedPriceAmount Int?
  rawPayload            Json
  externalUpdatedAt     DateTime?
  syncChecksum          String?
  lastSyncedAt          DateTime         @default(now())
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@unique([connectionId, externalId])
  @@index([storeId, connectionId])
  @@map("external_catalog_products")
}

model ExternalCatalogModifierGroup {
  id                String           @id @default(uuid())
  tenantId          String
  storeId           String
  connectionId      String
  channelType       CatalogChannelType
  externalId        String
  externalParentId  String?
  normalizedName    String?
  rawPayload        Json
  externalUpdatedAt DateTime?
  syncChecksum      String?
  lastSyncedAt      DateTime         @default(now())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([connectionId, externalId])
  @@index([storeId, connectionId])
  @@map("external_catalog_modifier_groups")
}

model ExternalCatalogModifierOption {
  id                    String           @id @default(uuid())
  tenantId              String
  storeId               String
  connectionId          String
  channelType           CatalogChannelType
  externalId            String
  externalParentId      String?
  normalizedName        String?
  normalizedPriceAmount Int?
  rawPayload            Json
  externalUpdatedAt     DateTime?
  syncChecksum          String?
  lastSyncedAt          DateTime         @default(now())
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@unique([connectionId, externalId])
  @@index([storeId, connectionId])
  @@map("external_catalog_modifier_options")
}

model ExternalCatalogProductModifierGroupLink {
  id                      String           @id @default(uuid())
  tenantId                String
  storeId                 String
  connectionId            String
  channelType             CatalogChannelType
  externalProductId       String
  externalModifierGroupId String
  rawPayload              Json?
  lastSyncedAt            DateTime         @default(now())
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@unique([connectionId, externalProductId, externalModifierGroupId])
  @@index([storeId, connectionId, externalProductId])
  @@map("external_catalog_product_modifier_group_links")
}

// ─── Channel Entity Mappings ──────────────────────────────────────────────────

model ChannelEntityMapping {
  id               String            @id @default(uuid())
  tenantId         String
  storeId          String
  entityType       CatalogEntityType
  internalEntityId String
  connectionId     String
  channelType      CatalogChannelType
  externalEntityId String
  externalParentId String?
  mappingStatus    MappingStatus     @default(ACTIVE)
  lastVerifiedAt   DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([connectionId, entityType, externalEntityId])
  @@unique([connectionId, entityType, internalEntityId])
  @@index([storeId, entityType, internalEntityId])
  @@index([storeId, connectionId, entityType])
  @@map("channel_entity_mappings")
}
