// ─── Channel Entity Mappings (Phase 3) ───────────────────────────────────────
//
// Links internal canonical catalog entities to their counterparts in an
// external channel (Loyverse, Uber Eats, DoorDash, …).
//
// Key invariants:
//   • One internal entity may map to at most ONE active external entity per
//     connection/entityType combination.
//   • One external entity may be linked to at most ONE active internal entity
//     per connection/entityType combination.
//   • These uniqueness constraints are enforced via partial unique indexes in
//     the migration SQL (WHERE status NOT IN ('ARCHIVED','UNMATCHED')) because
//     Prisma does not support partial unique indexes natively.
//
// TODO Phase 4: publish engine — reads ACTIVE mappings to build outbound payloads.
// TODO Phase 5: external change detection — flags ACTIVE mappings whose externalEntityId
//               disappears from the next import run.
// TODO Phase 6: conflict detection — compares field-level diffs between internal and external.
// TODO Phase 7: policy-based two-way sync — uses mappings as the routing table.

model ChannelEntityMapping {
  id           String @id @default(uuid())
  tenantId     String
  storeId      String
  connectionId String

  internalEntityType CatalogEntityType
  internalEntityId   String

  externalEntityType CatalogEntityType
  externalEntityId   String

  status CatalogMappingStatus @default(NEEDS_REVIEW)
  source CatalogMappingSource @default(AUTO)

  confidenceScore Float?
  matchReason     String?
  notes           String?

  lastValidatedAt DateTime?
  linkedAt        DateTime  @default(now())
  unlinkedAt      DateTime?

  // Phase 4: Publish summary fields — snapshot of the last outbound publish result.
  // Detailed per-operation history lives in CatalogPublishJob.
  lastPublishedAt   DateTime?
  lastPublishStatus CatalogPublishStatus?
  lastPublishAction CatalogPublishAction?
  lastPublishHash   String?
  lastPublishError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, storeId, connectionId, internalEntityType, internalEntityId])
  @@index([tenantId, storeId, connectionId, externalEntityType, externalEntityId])
  @@index([tenantId, storeId, connectionId, status])
  @@map("channel_entity_mappings")
}

// ─── Phase 4: Outbound Publish Layer ─────────────────────────────────────────
//
// Publish = one-way push from internal Beyond catalog → external channel.
// The mapping layer (ChannelEntityMapping) determines whether to CREATE or UPDATE.
// External normalized catalog is still primarily refreshed via import, not assumed
// to be authoritative from publish success alone.
//
// TODO Phase 5: external change detection after import
// TODO Phase 6: conflict detection between internal changes and external changes
// TODO Phase 7: policy-based two-way sync

enum CatalogPublishAction {
  CREATE
  UPDATE
  ARCHIVE
  UNARCHIVE
}

enum CatalogPublishStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
  CANCELLED
}

enum CatalogPublishScope {
  CATEGORY
  PRODUCT
  MODIFIER_GROUP
  MODIFIER_OPTION
  PRODUCT_CATEGORY_LINK
  PRODUCT_MODIFIER_GROUP_LINK
}

model CatalogPublishJob {
  id           String @id @default(uuid())
  tenantId     String
  storeId      String
  connectionId String

  internalEntityType CatalogEntityType?
  internalEntityId   String?

  scope  CatalogPublishScope
  action CatalogPublishAction
  status CatalogPublishStatus @default(PENDING)

  requestedByUserId String?
  triggerSource     String? // MANUAL_UI | BULK_UI | API | SYSTEM

  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?
  errorCode       String?

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, storeId, connectionId, status])
  @@index([tenantId, storeId, connectionId, internalEntityType, internalEntityId])
  @@map("catalog_publish_jobs")
}

// ─── Admin Jobs ───────────────────────────────────────────────────────────────

enum JobType {
  CATALOG_SYNC
  CONNECTION_VALIDATE
  CONNECTION_REFRESH_CHECK
  ORDER_RECOVERY_RETRY
  ORDER_RECONCILIATION_RETRY
  ANALYTICS_REBUILD
}

enum JobRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  SKIPPED
}

enum JobTriggerSource {
  SYSTEM
  ADMIN_MANUAL
  ADMIN_RETRY
}

model JobRun {
  id                  String           @id @default(uuid())
  tenantId            String?
  storeId             String?
  provider            String?
  jobType             JobType
  status              JobRunStatus     @default(QUEUED)
  triggerSource       JobTriggerSource
  triggeredByUserId   String?
  parentRunId         String?
  relatedEntityType   String?
  relatedEntityId     String?
  inputJson           Json?
  resultJson          Json?
  errorCode           String?
  errorMessage        String?
  queuedAt            DateTime?
  startedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  triggeredByUser User?    @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)
  parentRun       JobRun?  @relation("JobRunRetries", fields: [parentRunId], references: [id], onDelete: SetNull)
  childRuns       JobRun[] @relation("JobRunRetries")

  @@index([tenantId, storeId])
  @@index([status, createdAt])
  @@index([jobType, status])
  @@index([triggeredByUserId])
  @@index([parentRunId])
  @@map("job_runs")
}

