generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("FREE")
  status    String   @default("TRIAL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users  User[]
  stores Store[]

  @@map("tenants")
}

model User {
  id        String    @id @default(cuid())
  tenantId  String
  email     String    @unique
  name      String
  password  String
  role      String    @default("STAFF")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("users")
}

model Store {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  phone     String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  categories           Category[]
  menuItems            MenuItem[]
  orders               Order[]
  posIntegrations      PosIntegration[]
  deliveryIntegrations DeliveryIntegration[]
  subscriptionPlans    SubscriptionPlan[]

  @@map("stores")
}

model Category {
  id           String   @id @default(cuid())
  storeId      String
  name         String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store     Store      @relation(fields: [storeId], references: [id])
  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id          String   @id @default(cuid())
  storeId     String
  categoryId  String
  name        String
  description String?
  price       Int
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store        Store         @relation(fields: [storeId], references: [id])
  category     Category      @relation(fields: [categoryId], references: [id])
  optionGroups OptionGroup[]
  orderItems   OrderItem[]

  @@map("menu_items")
}

model OptionGroup {
  id            String @id @default(cuid())
  menuItemId    String
  name          String
  isRequired    Boolean @default(false)
  maxSelections Int     @default(1)

  menuItem MenuItem     @relation(fields: [menuItemId], references: [id])
  options  MenuOption[]

  @@map("option_groups")
}

model MenuOption {
  id              String @id @default(cuid())
  optionGroupId   String
  name            String
  additionalPrice Int    @default(0)

  optionGroup OptionGroup @relation(fields: [optionGroupId], references: [id])

  @@map("menu_options")
}

model Order {
  id              String   @id @default(cuid())
  storeId         String
  channelType     String
  externalOrderId String?
  status          String   @default("PENDING")
  totalAmount     Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store   Store       @relation(fields: [storeId], references: [id])
  items   OrderItem[]
  payment Payment?

  @@map("orders")
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Int
  totalPrice Int
  options    Json?

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

model Payment {
  id                    String    @id @default(cuid())
  orderId               String    @unique
  storeId               String
  method                String
  status                String    @default("PENDING")
  amount                Int
  provider              String?
  externalTransactionId String?
  paidAt                DateTime?
  createdAt             DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model PosIntegration {
  id              String    @id @default(cuid())
  storeId         String
  provider        String
  status          String    @default("DISCONNECTED")
  externalStoreId String?
  config          Json?
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, provider])
  @@map("pos_integrations")
}

model DeliveryIntegration {
  id             String    @id @default(cuid())
  storeId        String
  platform       String
  status         String    @default("DISCONNECTED")
  externalShopId String?
  config         Json?
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, platform])
  @@map("delivery_integrations")
}

model SubscriptionPlan {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  price     Int
  interval  String
  benefits  Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store         Store          @relation(fields: [storeId], references: [id])
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id              String    @id @default(cuid())
  planId          String
  customerId      String
  status          String    @default("ACTIVE")
  startDate       DateTime
  nextBillingDate DateTime
  cancelledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}
